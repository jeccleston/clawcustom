{
  "name": "ClawCustom",
  "description": "Modular AI assistant platform powered by Alibaba Cloud Qwen (DashScope)",
  "version": "2.0.0",
  "repository": {
    "url": "https://github.com/jeccleston/clawcustom",
    "branch": "master"
  },
  "build": {
    "type": "dockerfile",
    "path": "Dockerfile",
    "cacheFrom": "ghcr.io/astral-sh/uv:python3.12-bookworm-slim"
  },
  "runtime": {
    "type": "docker-compose",
    "file": "docker-compose.coolify.yml",
    "volumes": [
      {
        "name": "clawcustom-data",
        "mountPath": "/root/.clawcustom",
        "persistent": true
      }
    ],
    "ports": [
      {
        "internal": 18790,
        "protocol": "http",
        "visible": true
      }
    ],
    "environment": {
      "required": [
        {
          "name": "DASHSCOPE_API_KEY",
          "description": "Alibaba Cloud DashScope API key (get from dashscope.console.aliyun.com)",
          "default": "",
          "secret": true
        }
      ],
      "optional": [
        {
          "name": "DASHSCOPE_API_BASE",
          "description": "DashScope API base URL (coding-intl endpoint)",
          "default": "https://coding-intl.dashscope.aliyuncs.com/v1"
        },
        {
          "name": "AI_MODEL",
          "description": "Qwen model: qwen3.5-plus (recommended), qwen-max, qwen-plus, qwen-turbo",
          "default": "qwen3.5-plus"
        },
        {
          "name": "AI_PROVIDER",
          "description": "Provider (dashscope recommended)",
          "default": "dashscope"
        },
        {
          "name": "AI_TEMPERATURE",
          "description": "Model temperature (0.0-1.0, lower = more focused)",
          "default": "0.1"
        },
        {
          "name": "AI_MAX_TOKENS",
          "description": "Max tokens for responses",
          "default": "8192"
        },
        {
          "name": "BRAVE_SEARCH_API_KEY",
          "description": "Brave Search API key for web search",
          "default": "",
          "secret": true
        },
        {
          "name": "TELEGRAM_ENABLED",
          "description": "Enable Telegram channel",
          "default": "false"
        },
        {
          "name": "TELEGRAM_BOT_TOKEN",
          "description": "Telegram bot token from @BotFather",
          "default": "",
          "secret": true
        },
        {
          "name": "DISCORD_ENABLED",
          "description": "Enable Discord channel",
          "default": "false"
        },
        {
          "name": "DISCORD_BOT_TOKEN",
          "description": "Discord bot token",
          "default": "",
          "secret": true
        },
        {
          "name": "WHATSAPP_ENABLED",
          "description": "Enable WhatsApp (requires QR scan after deploy)",
          "default": "false"
        },
        {
          "name": "RESTRICT_TO_WORKSPACE",
          "description": "Restrict file access to workspace only (security)",
          "default": "true"
        },
        {
          "name": "CPU_LIMIT",
          "description": "CPU cores limit",
          "default": "1"
        },
        {
          "name": "MEMORY_LIMIT",
          "description": "Memory limit (e.g., 1G, 2G)",
          "default": "1G"
        },
        {
          "name": "OPENROUTER_API_KEY",
          "description": "OpenRouter API key (alternative provider)",
          "default": "",
          "secret": true
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "description": "Anthropic API key (alternative provider)",
          "default": "",
          "secret": true
        }
      ]
    },
    "resources": {
      "cpu": {
        "limit": "1",
        "reservation": "0.25"
      },
      "memory": {
        "limit": "1G",
        "reservation": "256M"
      }
    },
    "healthCheck": {
      "command": "clawcustom status",
      "interval": 60,
      "timeout": 10,
      "retries": 3,
      "startPeriod": 30
    },
    "restartPolicy": "unless-stopped"
  },
  "features": [
    "🤖 Powered by Alibaba Cloud Qwen (DashScope)",
    "🚀 Optimized for DashScope Coding Plan endpoint",
    "🧩 7 Specialized Worker Agents (Coder, Researcher, Writer, Analyst, Reviewer, Architect, DevOps)",
    "🐳 Docker Development Environments (8 pre-built templates)",
    "📈 Stock Market Analysis & Portfolio Tracking",
    "📄 Document Processing (Word, PDF)",
    "💬 Multi-Platform Chat (Telegram, Discord, WhatsApp, Slack, etc.)",
    "🔌 15+ LLM Providers Supported (DashScope, OpenRouter, Anthropic, etc.)",
    "🧩 Modular Plugin System",
    "👤 Interactive Onboarding Wizard",
    "📚 Context-Aware Help System"
  ],
  "postDeploy": {
    "instructions": [
      "1. Get DashScope API key from https://dashscope.console.aliyun.com",
      "2. Configure DASHSCOPE_API_KEY in Environment Variables",
      "3. Set DASHSCOPE_API_BASE to: https://coding-intl.dashscope.aliyuncs.com/v1",
      "4. Model is pre-configured: qwen3.5-plus (balanced performance/cost)",
      "5. Wait for health check to pass (~2-3 minutes)",
      "6. Test via Terminal: docker exec -it <container> clawcustom agent -m 'help'",
      "7. Optional: Enable chat channels (Telegram, Discord, WhatsApp)",
      "8. For WhatsApp: Run 'clawcustom channels login' in Terminal and scan QR code"
    ],
    "tips": [
      "Use 'clawcustom onboard' for interactive setup",
      "Type 'help' in agent chat to see available commands",
      "Spawn workers: 'use coder to build a REST API'",
      "Create environments: 'create python environment'",
      "Get help: 'help workers', 'help environments', 'help commands'",
      "DashScope provides excellent Chinese language support"
    ]
  },
  "documentation": {
    "readme": "README.md",
    "coolifyGuide": "COOLIFY_QUICK_START.md",
    "dashscopeSetup": "DASHSCOPE_SETUP.md",
    "modularSystem": "MODULAR_SYSTEM.md",
    "workerAgents": "WORKER_AGENTS.md"
  },
  "author": {
    "name": "clawcustom contributors",
    "url": "https://github.com/jeccleston/clawcustom"
  },
  "license": "MIT",
  "tags": [
    "ai",
    "chatbot",
    "assistant",
    "llm",
    "agent",
    "workers",
    "docker",
    "qwen",
    "dashscope",
    "alibaba",
    "telegram",
    "discord",
    "whatsapp",
    "modular",
    "fullstack"
  ],
  "screenshots": [],
  "support": {
    "discord": "https://discord.gg/MnCvHqpUGB",
    "issues": "https://github.com/jeccleston/clawcustom/issues",
    "discussions": "https://github.com/jeccleston/clawcustom/discussions",
    "dashscope": "https://help.aliyun.com/zh/dashscope/"
  }
}
