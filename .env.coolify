# Coolify Environment Variables for ClawCustom
# Copy these to your Coolify project's environment variables section

# ============================================
# 🤖 LLM Provider (Choose ONE and set API key)
# ============================================

# Option 1: OpenRouter (Recommended - Access to all models)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Option 2: Anthropic (Direct Claude access)
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Option 3: DashScope (Alibaba Cloud - Qwen models)
# Get key: https://dashscope.console.aliyun.com
DASHSCOPE_API_KEY=

# Option 4: DeepSeek
# Get key: https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Option 5: Groq (Fast inference + Whisper transcription)
# Get key: https://console.groq.com
GROQ_API_KEY=

# ============================================
# 🎯 AI Model Configuration
# ============================================

# Model selection (format: provider/model-name)
# Examples:
#   - anthropic/claude-opus-4-5 (best overall)
#   - anthropic/claude-3-5-sonnet (great value)
#   - openai/gpt-4o (OpenAI)
#   - deepseek/deepseek-chat (cost-effective)
#   - dashscope/qwen-max (China region)
AI_MODEL=anthropic/claude-opus-4-5

# Provider preference (auto, openrouter, anthropic, deepseek, dashscope)
AI_PROVIDER=auto

# Temperature (0.0 - 1.0)
# Lower = more focused, Higher = more creative
AI_TEMPERATURE=0.1

# Max tokens for responses
AI_MAX_TOKENS=8192

# ============================================
# 🔍 Optional: Web Search
# ============================================
# Get key: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# ============================================
# 💬 Optional: Chat Channels
# ============================================

# Telegram: Create bot via @BotFather → /newbot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# Discord: Create app at https://discord.com/developers
# Enable MESSAGE CONTENT INTENT
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# WhatsApp: Run 'nanobot channels login' and scan QR
WHATSAPP_ENABLED=false

# ============================================
# 🛡️ Security
# ============================================

# Restrict file access to workspace only
RESTRICT_TO_WORKSPACE=true

# ============================================
# 💾 Resource Limits
# ============================================

CPU_LIMIT=1
CPU_RESERVATION=0.25
MEMORY_LIMIT=1G
MEMORY_RESERVATION=256M

# For production with heavy usage:
# CPU_LIMIT=2
# MEMORY_LIMIT=2G

# ============================================
# 🌐 Network
# ============================================

GATEWAY_PORT=18790
