# Coolify Environment Variables for nanobot
# Copy these to your Coolify project's environment variables

# ============================================
# LLM Provider (Choose ONE and set API key)
# ============================================

# OpenRouter (Recommended - Access to all models)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Anthropic (Direct Claude access)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DashScope (Alibaba Cloud - Qwen models)
DASHSCOPE_API_KEY=your-dashscope-key

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key

# Groq (Fast inference + Whisper transcription)
GROQ_API_KEY=gsk_your-key-here

# ============================================
# AI Model Configuration
# ============================================

# Model selection (examples):
# - anthropic/claude-opus-4-5
# - anthropic/claude-3-5-sonnet
# - openai/gpt-4o
# - deepseek/deepseek-chat
# - dashscope/qwen-max
AI_MODEL=anthropic/claude-opus-4-5

# Provider preference (auto, openrouter, anthropic, deepseek, dashscope)
AI_PROVIDER=auto

# Temperature (0.0 - 1.0, lower = more focused)
AI_TEMPERATURE=0.1

# Max tokens for responses
AI_MAX_TOKENS=8192

# ============================================
# Optional: Web Search (Brave Search API)
# ============================================

BRAVE_SEARCH_API_KEY=

# ============================================
# Optional: Chat Channels
# ============================================

# Telegram
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# Discord
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# WhatsApp (requires QR scan after deploy)
WHATSAPP_ENABLED=false

# ============================================
# Resource Limits
# ============================================

CPU_LIMIT=1
CPU_RESERVATION=0.25
MEMORY_LIMIT=1G
MEMORY_RESERVATION=256M

# ============================================
# Gateway Port (Coolify will auto-assign)
# ============================================

GATEWAY_PORT=18790

# ============================================
# Security
# ============================================

# Restrict file access to workspace only (recommended: true)
RESTRICT_TO_WORKSPACE=true
