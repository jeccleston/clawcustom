# Coolify Environment Variables for ClawCustom
# Copy these to your Coolify project's environment variables section

# ============================================
# 🤖 AI Provider: DashScope (Alibaba Cloud)
# ============================================
# Primary provider for ClawCustom
# Get API Key: https://dashscope.console.aliyun.com
# API Docs: https://help.aliyun.com/zh/dashscope/

DASHSCOPE_API_KEY=your-dashscope-api-key-here

# DashScope API Base URL (Coding Plan endpoint)
# This is the international coding-specific endpoint
DASHSCOPE_API_BASE=https://coding-intl.dashscope.aliyuncs.com/v1

# ============================================
# 🎯 Model Configuration
# ============================================

# Qwen Model (DashScope)
# Options:
#   - qwen3.5-plus: Best balance of performance and cost (recommended)
#   - qwen-max: Most powerful, higher cost
#   - qwen-plus: Balanced performance
#   - qwen-turbo: Fastest, lowest cost
AI_MODEL=qwen3.5-plus

# Provider (DashScope)
AI_PROVIDER=dashscope

# Model temperature (0.0 - 1.0)
# Lower = more focused and deterministic
# Higher = more creative and varied
AI_TEMPERATURE=0.1

# Max tokens for responses
AI_MAX_TOKENS=8192

# ============================================
# 🔍 Optional: Web Search (Brave Search API)
# ============================================
# Get key: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# ============================================
# 💬 Optional: Chat Channels
# ============================================

# Telegram: Create bot via @BotFather → /newbot
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=

# Discord: Create app at https://discord.com/developers
# Enable MESSAGE CONTENT INTENT
DISCORD_ENABLED=false
DISCORD_BOT_TOKEN=

# WhatsApp: Run 'clawcustom channels login' and scan QR
WHATSAPP_ENABLED=false

# ============================================
# 🛡️ Security
# ============================================

# Restrict file access to workspace only
RESTRICT_TO_WORKSPACE=true

# ============================================
# 💾 Resource Limits
# ============================================

CPU_LIMIT=1
CPU_RESERVATION=0.25
MEMORY_LIMIT=1G
MEMORY_RESERVATION=256M

# For production with heavy usage:
# CPU_LIMIT=2
# MEMORY_LIMIT=2G

# ============================================
# 🌐 Network
# ============================================

GATEWAY_PORT=18790
