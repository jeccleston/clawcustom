# Environment Variables for DashScope
# Add these to your .env file or shell

# DashScope API Key (required)
export DASHSCOPE_API_KEY="YOUR_DASHSCOPE_API_KEY"

# Custom API Base (optional - for coding-intl endpoint)
export DASHSCOPE_API_BASE="https://coding-intl.dashscope.aliyuncs.com/v1"

# Or use OpenAI-compatible custom provider
export NANOBOT__PROVIDERS__CUSTOM__API_KEY="YOUR_DASHSCOPE_API_KEY"
export NANOBOT__PROVIDERS__CUSTOM__API_BASE="https://coding-intl.dashscope.aliyuncs.com/v1"
export NANOBOT__AGENTS__DEFAULTS__PROVIDER="custom"
export NANOBOT__AGENTS__DEFAULTS__MODEL="qwen-max"
